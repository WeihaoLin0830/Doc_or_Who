DOCUMENTWHO_DATASET_DIR=dataset_default
DOCUMENTWHO_DATA_DIR=data
DOCUMENTWHO_UPLOAD_DIR=uploads
DOCUMENTWHO_DATABASE_URL=sqlite:///data/documentwho.db
DOCUMENTWHO_EMBEDDING_PROVIDER=sentence_transformers
DOCUMENTWHO_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
DOCUMENTWHO_SPACY_MODEL=es_core_news_md
DOCUMENTWHO_ENABLE_OCR=true
DOCUMENTWHO_OCR_PROVIDER=tesseract
DOCUMENTWHO_OCR_LANGUAGES=spa+eng
DOCUMENTWHO_OCR_DPI=200
DOCUMENTWHO_OCR_MAX_PAGES=20
# DOCUMENTWHO_TESSERACT_CMD=/usr/bin/tesseract
DOCUMENTWHO_SEARCH_TOP_K=50
DOCUMENTWHO_FINAL_TOP_K=10
DOCUMENTWHO_FILE_SIZE_LIMIT_MB=50
